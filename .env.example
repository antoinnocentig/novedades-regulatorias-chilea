# Vercel KV (Redis) — caché mensual
# Obtener en: vercel.com → Storage → KV
KV_REST_API_URL=https://<tu-kv>.kv.vercel-storage.com
KV_REST_API_TOKEN=<tu-token>

# Secreto para el endpoint cron (llamadas externas)
CRON_SECRET=<secreto-aleatorio>

# URL del sitio
NEXT_PUBLIC_SITE_URL=https://<proyecto>.vercel.app
